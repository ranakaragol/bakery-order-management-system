# Root-level reference file.
# Copy the backend section into backend/.env and frontend section into frontend/.env

# backend/.env
PORT=5001
MONGO_URI=mongodb://127.0.0.1:27017/bakery_order_management
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
CLIENT_URL=http://127.0.0.1:5173
ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:4173,http://localhost:4173
AUTH_COOKIE_NAME=pasali_auth
AUTH_COOKIE_MAX_AGE_MS=604800000
AUTH_COOKIE_SAME_SITE=lax
# AUTH_COOKIE_SECURE=true
# AUTH_COOKIE_DOMAIN=.example.com
# CSRF_PROTECTION_ENABLED=false
# CSRF_COOKIE_NAME=pasali_csrf
# AUTH_COOKIE_ALLOW_INSECURE_LOCALHOST_NONE=true
# `seed` ve `seed:admin` ayni admin/invoice contract'ini kullanir.
# Zorunlu tax alanlari dogrulanmadan destructive seed islemi baslamaz.
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=ChangeMe123!
ADMIN_SEED_FIRST_NAME=Example
ADMIN_SEED_LAST_NAME=Admin
ADMIN_SEED_PHONE=+90 555 000 00 00
ADMIN_SEED_ADDRESS=Example Address
ADMIN_SEED_TAX_NUMBER=0000000000
ADMIN_SEED_TAX_OFFICE=Example Tax Office

# frontend/.env
# Yerel gelistirmede ayni hostname'i kullanmak icin bos birakabilirsiniz.
# VITE_API_URL=
VITE_CSRF_COOKIE_NAME=pasali_csrf
