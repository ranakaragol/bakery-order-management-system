{
  "name": "bakery-order-management-system",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "description": "Modern bakery ordering platform with React frontend and Express backend.",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:backend": "npm --prefix backend run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:status": "node scripts/dev-status.mjs",
    "start:backend": "npm --prefix backend run start",
    "lint:catalog": "node scripts/lint-catalog.mjs",
    "lint:frontend": "eslint frontend/src frontend/vite.config.js",
    "lint:backend": "eslint backend/src shared scripts",
    "lint:code": "npm run lint:frontend && npm run lint:backend",
    "lint": "npm run lint:catalog && npm run lint:code",
    "test": "npm --prefix backend run test && npm --prefix frontend run test",
    "build": "npm --prefix frontend run build",
    "check": "npm run lint && npm run test && npm run build",
    "build:frontend": "npm --prefix frontend run build",
    "test:backend": "npm --prefix backend run test"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "eslint": "^9.39.5",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.7.0"
  }
}
